@page
@model Student_Managment_System.Pages.Courses.CreateModel

<h2>Add New Course</h2>

<form method="post">
    <div class="mb-3">
        <label>Course Name</label>
        <input asp-for="CourseName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Credits</label>
        <input asp-for="Credits" type="number" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">
        Save
    </button>

    <a href="/Courses/Index" class="btn btn-secondary">
        Cancel
    </a>
</form>