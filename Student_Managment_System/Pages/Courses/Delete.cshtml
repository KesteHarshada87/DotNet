@page
@model Student_Managment_System.Pages.Courses.DeleteModel

<h2>Delete Course</h2>

<div class="alert alert-danger">
    <h4>Are you sure you want to delete this course?</h4>
</div>

<div class="mb-3">
    <strong>Course Name:</strong> @Model.CourseName
</div>

<div class="mb-3">
    <strong>Credits:</strong> @Model.Credits
</div>

<form method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Confirm Delete
    </button>

    <a asp-page="/Courses/Index" class="btn btn-secondary">
        Cancel
    </a>
</form>